<Window x:Class="ModemPoolManager.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:ModemPoolManager.Converters"
        mc:Ignorable="d"
        Title="مدير المودمات - Modem Pool Manager Pro" 
        Height="900" Width="1400"
        FlowDirection="RightToLeft"
        Background="#000000"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        MinHeight="700" MinWidth="1100">

    <Window.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <converters:OperatorToBrushConverter x:Key="OperatorToBrushConverter"/>
        <converters:OperatorToGlowColorConverter x:Key="OperatorToGlowColorConverter"/>
        <converters:SignalColorConverter x:Key="SignalColorConverter"/>
        <converters:SignalBarsToOpacityConverter x:Key="SignalBarsToOpacityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <converters:OtpVisibilityConverter x:Key="OtpVisibilityConverter"/>
        <converters:OtpTextVisibilityConverter x:Key="OtpTextVisibilityConverter"/>
        <converters:TransferStatusToColorConverter x:Key="TransferStatusToColorConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#238636"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2EA043"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#21262D"/>
                    <Setter Property="Foreground" Value="#484F58"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BlueButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#1F6FEB"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#388BFD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GreenButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#238636"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2EA043"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OrangeButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#D29922"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E3B341"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RedButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#DA3633"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F85149"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#21262D"/>
                    <Setter Property="BorderBrush" Value="#8B949E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#58A6FF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#58A6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background" Value="#0D0D0D"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="BorderBrush" Value="#1A1A1A"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="VodafoneTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#E60000"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#E60000"/>
                                <Setter TargetName="Border" Property="Background" Value="#1A0000"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#E60000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OrangeTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#FF7900"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#FF7900"/>
                                <Setter TargetName="Border" Property="Background" Value="#1A0F00"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#FF7900"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EtisalatTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#80B826"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#80B826"/>
                                <Setter TargetName="Border" Property="Background" Value="#0A1A00"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#80B826"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#F0F6FC"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#F78166"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#C9D1D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#000000" BorderBrush="#1A1A1A" BorderThickness="0,0,0,1" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="◉" FontSize="24" Foreground="#238636" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="مدير المودمات" FontSize="20" FontWeight="Bold" Foreground="#F0F6FC" VerticalAlignment="Center"/>
                    <Border Background="#21262D" CornerRadius="12" Padding="8,4" Margin="16,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Pro" FontSize="11" Foreground="#58A6FF" FontWeight="Bold"/>
                    </Border>
                </StackPanel>

                <Border Grid.Column="1" Background="#161B22" CornerRadius="6" Padding="16,8" Margin="20,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="#0D419D" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="●" Foreground="#3FB950" FontSize="8" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding ConnectedCount}" FontSize="12" Foreground="#C9D1D9" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#30363D" Width="1" Margin="4,2"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="⏳" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Visibility="{Binding HasActiveOperations, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasActiveOperations}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                             From="0" To="360" Duration="0:0:2"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <TextBlock.RenderTransform>
                                    <RotateTransform/>
                                </TextBlock.RenderTransform>
                                <TextBlock.RenderTransformOrigin>0.5,0.5</TextBlock.RenderTransformOrigin>
                            </TextBlock>
                            <TextBlock Text="{Binding CurrentOperationText}" FontSize="13" Foreground="#58A6FF" 
                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                       Visibility="{Binding HasActiveOperations, Converter={StaticResource BoolToVisibility}}"/>
                            <TextBlock Text="جاهز للعمل" FontSize="13" Foreground="#8B949E" 
                                       VerticalAlignment="Center"
                                       Visibility="{Binding HasActiveOperations, Converter={StaticResource InverseBoolToVisibility}}"/>
                        </StackPanel>
                        
                        <Border Grid.Column="2" Background="#21262D" CornerRadius="4" Padding="8,4">
                            <TextBlock Text="{Binding TotalPorts, StringFormat='المنافذ: {0}'}" FontSize="11" Foreground="#8B949E"/>
                        </Border>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="⚙ الإعدادات" Style="{StaticResource GhostButton}" Click="SettingsButton_Click"/>
                    <Button Content="↻ تحديث" Style="{StaticResource BlueButton}" Command="{Binding RefreshPortsCommand}" 
                            IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}"/>
                    <Button x:Name="CloseButton" Content="✕" Click="CloseButton_Click"
                            Width="40" Height="40" Margin="10,0,0,0"
                            FontSize="18" FontWeight="Bold"
                            Background="#DA3633" Foreground="White"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#DA3633"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F85149"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Padding="10">
            <TabControl.Resources>
                <Style TargetType="TabControl">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabControl">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Background="#161B22" BorderBrush="#30363D" BorderThickness="0,0,0,1" Padding="10,0">
                                        <TabPanel IsItemsHost="True"/>
                                    </Border>
                                    <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>
            
            <TabItem Header="🏠 لوحة التحكم" Style="{StaticResource TabItemStyle}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                        <Button Command="{Binding ToggleControlPanelCommand}" 
                                Style="{StaticResource GhostButton}"
                                ToolTip="إخفاء/إظهار لوحة التحكم"
                                Padding="12,6"
                                Content="{Binding ControlPanelToggleText}"/>
                    </StackPanel>

                    <Border Grid.Row="1" Style="{StaticResource CardPanel}" 
                            Visibility="{Binding IsControlPanelVisible, Converter={StaticResource BoolToVisibility}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Text="{Binding UssdCode, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource ModernTextBox}" 
                                         FontSize="18" FontWeight="Bold"
                                         FlowDirection="LeftToRight"/>
                                
                                <Button Grid.Column="1" Content="▶ تنفيذ على الكل" 
                                        Command="{Binding ExecuteUssdCommand}"
                                        Style="{StaticResource OrangeButton}"
                                        FontSize="15" Padding="24,12"
                                        IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}"/>
                            </Grid>

                            <StackPanel Grid.Row="1" Orientation="Horizontal">
                                <TextBlock Text="أوامر سريعة:" Foreground="#8B949E" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="13"/>
                                
                                <TextBox Text="{Binding CustomUssd1, UpdateSourceTrigger=PropertyChanged}" 
                                         Width="90" Style="{StaticResource ModernTextBox}" FontSize="13" FlowDirection="LeftToRight"/>
                                <Button Content="▶" Command="{Binding ExecuteCustomUssd1Command}" 
                                        Style="{StaticResource ModernButton}" Padding="12,8"
                                        IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}"/>

                                <TextBox Text="{Binding CustomUssd2, UpdateSourceTrigger=PropertyChanged}" 
                                         Width="90" Style="{StaticResource ModernTextBox}" FontSize="13" Margin="12,0,0,0" FlowDirection="LeftToRight"/>
                                <Button Content="▶" Command="{Binding ExecuteCustomUssd2Command}" 
                                        Style="{StaticResource ModernButton}" Padding="12,8"
                                        IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}"/>

                                <TextBox Text="{Binding CustomUssd3, UpdateSourceTrigger=PropertyChanged}" 
                                         Width="90" Style="{StaticResource ModernTextBox}" FontSize="13" Margin="12,0,0,0" FlowDirection="LeftToRight"/>
                                <Button Content="▶" Command="{Binding ExecuteCustomUssd3Command}" 
                                        Style="{StaticResource ModernButton}" Padding="12,8"
                                        IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}"/>

                                <Border Width="1" Background="#30363D" Margin="20,0"/>

                                <Button Content="☑ تحديد الكل" Command="{Binding SelectAllModemsCommand}" Style="{StaticResource GhostButton}"/>
                                <Button Content="☐ إلغاء" Command="{Binding DeselectAllModemsCommand}" Style="{StaticResource GhostButton}"/>
                                <Button Content="🗑 مسح" Command="{Binding ClearResultsCommand}" Style="{StaticResource RedButton}"/>
                                <Button Content="📱 جلب الأرقام" Command="{Binding GetPhoneNumbersCommand}" 
                                        Style="{StaticResource BlueButton}"
                                        IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}"/>
                                <Button Content="📶 تحديث الإشارات" Command="{Binding RefreshAllSignalsCommand}" 
                                        Style="{StaticResource OrangeButton}"
                                        IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}"/>
                                
                                <Button Content="🔍 Get Missed" Command="{Binding GetMissedModemsCommand}" 
                                        Style="{StaticResource RedButton}"
                                        ToolTip="البحث عن المودمات المفقودة وإعادة تشغيلها"
                                        IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}"/>
                            </StackPanel>

                            <Border Grid.Row="2" Background="#161B22" CornerRadius="6" Padding="12" Margin="0,12,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Grid.Row="0" Text="⚡ تنفيذ متوازي متعدد الأكواد" FontSize="14" FontWeight="Bold" Foreground="#F0F6FC" Margin="0,0,0,8"/>
                                    
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0">
                                            <TextBox Text="{Binding BatchUssdCode1, UpdateSourceTrigger=PropertyChanged}" 
                                                     Style="{StaticResource ModernTextBox}" Margin="0,0,0,4"
                                                     FlowDirection="LeftToRight" FontSize="13"/>
                                            <TextBox Text="{Binding BatchUssdCode2, UpdateSourceTrigger=PropertyChanged}" 
                                                     Style="{StaticResource ModernTextBox}" Margin="0,0,0,4"
                                                     FlowDirection="LeftToRight" FontSize="13"/>
                                            <TextBox Text="{Binding BatchUssdCode3, UpdateSourceTrigger=PropertyChanged}" 
                                                     Style="{StaticResource ModernTextBox}" Margin="0,0,0,4"
                                                     FlowDirection="LeftToRight" FontSize="13"/>
                                            <TextBox Text="{Binding BatchUssdCode4, UpdateSourceTrigger=PropertyChanged}" 
                                                     Style="{StaticResource ModernTextBox}" Margin="0,0,0,4"
                                                     FlowDirection="LeftToRight" FontSize="13"/>
                                            <TextBox Text="{Binding BatchUssdCode5, UpdateSourceTrigger=PropertyChanged}" 
                                                     Style="{StaticResource ModernTextBox}"
                                                     FlowDirection="LeftToRight" FontSize="13"/>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                            <Button Content="▶ تنفيذ الكل" 
                                                    Command="{Binding ExecuteBatchUssdCommand}"
                                                    Style="{StaticResource OrangeButton}"
                                                    FontSize="14" Padding="20,10"
                                                    IsEnabled="{Binding IsBatchExecuting, Converter={StaticResource InverseBoolConverter}}"/>
                                            <Button Content="🗑 مسح" 
                                                    Command="{Binding ClearBatchCodesCommand}"
                                                    Style="{StaticResource GhostButton}"
                                                    FontSize="12" Margin="0,8,0,0"/>
                                            <TextBlock Text="{Binding BatchExecutionSession, StringFormat='جلسة: {0}'}" 
                                                       FontSize="11" Foreground="#8B949E" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Modems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4" Rows="3"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="6" Background="#000000" 
                                            BorderBrush="{Binding Operator, Converter={StaticResource OperatorToBrushConverter}}" 
                                            BorderThickness="2" CornerRadius="8" MinHeight="200">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect ShadowDepth="0" BlurRadius="15" 
                                                                          Color="{Binding Operator, Converter={StaticResource OperatorToGlowColorConverter}}"
                                                                          Opacity="0.6"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <EventTrigger RoutedEvent="Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                                                 From="0.3" To="0.9" Duration="0:0:2"/>
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                                 From="10" To="25" Duration="0:0:2"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="🔄 إعادة تشغيل المودم" 
                                                          Command="{Binding DataContext.RestartModemCommand, Source={x:Reference Name=RootWindow}}"
                                                          CommandParameter="{Binding}"/>
                                                <MenuItem Header="📋 نسخ الرقم" 
                                                          Command="{Binding DataContext.CopyPhoneNumberCommand, Source={x:Reference Name=RootWindow}}"
                                                          CommandParameter="{Binding}"/>
                                                <Separator/>
                                                <MenuItem Header="📶 تحديث الإشارة" 
                                                          Command="{Binding DataContext.RefreshModemSignalCommand, Source={x:Reference Name=RootWindow}}"
                                                          CommandParameter="{Binding}"/>
                                                <MenuItem Header="📱 جلب الرقم" 
                                                          Command="{Binding DataContext.RefreshModemPhoneNumberCommand, Source={x:Reference Name=RootWindow}}"
                                                          CommandParameter="{Binding}"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0" Background="#0D0D0D" Margin="0,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" 
                                                          Margin="8,6"/>

                                                <TextBlock Grid.Column="1" Text="{Binding PhoneNumber}" FontSize="32" FontWeight="Bold"
                                                           Foreground="{Binding Operator, Converter={StaticResource OperatorToBrushConverter}}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Margin="0,8" FontFamily="Consolas"/>

                                                <Border Grid.Column="2" Background="#21262D" BorderBrush="#30363D" BorderThickness="1" 
                                                        Padding="6,3" Margin="8,6" CornerRadius="4" ToolTip="{Binding SignalStrength}" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Height="14">
                                                        <Rectangle Width="3" Height="4" Margin="0,0,1,0" VerticalAlignment="Bottom"
                                                                   Fill="{Binding SignalColor, Converter={StaticResource SignalColorConverter}}"
                                                                   Opacity="{Binding SignalBars, Converter={StaticResource SignalBarsToOpacityConverter}, ConverterParameter=1}"/>
                                                        <Rectangle Width="3" Height="6" Margin="0,0,1,0" VerticalAlignment="Bottom"
                                                                   Fill="{Binding SignalColor, Converter={StaticResource SignalColorConverter}}"
                                                                   Opacity="{Binding SignalBars, Converter={StaticResource SignalBarsToOpacityConverter}, ConverterParameter=2}"/>
                                                        <Rectangle Width="3" Height="8" Margin="0,0,1,0" VerticalAlignment="Bottom"
                                                                   Fill="{Binding SignalColor, Converter={StaticResource SignalColorConverter}}"
                                                                   Opacity="{Binding SignalBars, Converter={StaticResource SignalBarsToOpacityConverter}, ConverterParameter=3}"/>
                                                        <Rectangle Width="3" Height="11" Margin="0,0,1,0" VerticalAlignment="Bottom"
                                                                   Fill="{Binding SignalColor, Converter={StaticResource SignalColorConverter}}"
                                                                   Opacity="{Binding SignalBars, Converter={StaticResource SignalBarsToOpacityConverter}, ConverterParameter=4}"/>
                                                        <Rectangle Width="3" Height="14" VerticalAlignment="Bottom"
                                                                   Fill="{Binding SignalColor, Converter={StaticResource SignalColorConverter}}"
                                                                   Opacity="{Binding SignalBars, Converter={StaticResource SignalBarsToOpacityConverter}, ConverterParameter=5}"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <Border Grid.Row="2" Background="#0D0D0D" Padding="8,6" CornerRadius="0,0,6,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Right">
                                                        <ToggleButton x:Name="SmsToggleButton" ToolTip="الرسائل" Cursor="Hand" Margin="0,0,4,0"
                                                                      IsChecked="{Binding IsSmsPopupOpen, Mode=TwoWay}">
                                                            <ToggleButton.Template>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border Background="#1F6FEB" BorderBrush="#388BFD" BorderThickness="1" 
                                                                            CornerRadius="4" Padding="8,4" x:Name="border">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock Text="✉" FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                                                                            <TextBlock Text="{Binding UnreadSmsCount}" FontSize="11" Foreground="White" 
                                                                                       VerticalAlignment="Center" Margin="4,0,0,0" FontWeight="Bold"
                                                                                       Visibility="{Binding UnreadSmsCount, Converter={StaticResource StringToVisibility}}"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="border" Property="Background" Value="#388BFD"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsChecked" Value="True">
                                                                            <Setter TargetName="border" Property="Background" Value="#58A6FF"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </ToggleButton.Template>
                                                        </ToggleButton>

                                                        <Button ToolTip="تحديث الإشارة" Cursor="Hand" Margin="0,0,4,0"
                                                                Command="{Binding DataContext.RefreshModemSignalCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="#21262D" BorderBrush="#30363D" BorderThickness="1" 
                                                                            CornerRadius="4" Padding="8,4" x:Name="border">
                                                                        <TextBlock Text="📶" FontSize="12" Foreground="#58A6FF" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="border" Property="Background" Value="#30363D"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>

                                                        <Button ToolTip="تحديث الرقم" Cursor="Hand" Margin="0,0,4,0"
                                                                Command="{Binding DataContext.RefreshModemPhoneNumberCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="#21262D" BorderBrush="#30363D" BorderThickness="1" 
                                                                            CornerRadius="4" Padding="8,4" x:Name="border">
                                                                        <TextBlock Text="📱" FontSize="12" Foreground="#D29922" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="border" Property="Background" Value="#30363D"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>

                                                        <Border Background="#21262D" BorderBrush="#30363D" BorderThickness="1" 
                                                                CornerRadius="4" Padding="6,4" Margin="0,0,4,0" ToolTip="حالة تجديد الصلاحية"
                                                                Visibility="{Binding DataContext.AutoRenewValidityForAll, Source={x:Reference Name=RootWindow}, Converter={StaticResource BoolToVisibility}}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="✅" FontSize="12" Foreground="#3FB950" VerticalAlignment="Center"
                                                                           Visibility="{Binding ValidityRenewed, Converter={StaticResource BoolToVisibility}}"/>
                                                                <TextBlock Text="⏳" FontSize="12" Foreground="#D29922" VerticalAlignment="Center"
                                                                           Visibility="{Binding IsRenewingValidity, Converter={StaticResource BoolToVisibility}}"/>
                                                            </StackPanel>
                                                        </Border>
                                                        
                                                        <Border Background="{Binding IsAuthorized, Converter={StaticResource BoolToVisibility}, ConverterParameter=#238636}" 
                                                                BorderBrush="#3FB950" BorderThickness="1" 
                                                                CornerRadius="4" Padding="6,4" Margin="0,0,4,0" ToolTip="صلاحية مفعلة"
                                                                Visibility="{Binding IsAuthorized, Converter={StaticResource BoolToVisibility}}">
                                                            <TextBlock Text="✓" FontSize="12" Foreground="#3FB950" VerticalAlignment="Center" FontWeight="Bold"/>
                                                        </Border>

                                                        <Button ToolTip="{Binding IsInternetEnabled, Converter={StaticResource BoolToVisibility}, ConverterParameter='إيقاف الإنترنت|تشغيل الإنترنت'}" 
                                                                Cursor="Hand" Margin="0,0,4,0"
                                                                Command="{Binding DataContext.ToggleModemInternetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                IsEnabled="{Binding IsEnablingInternet, Converter={StaticResource InverseBoolConverter}}">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{Binding IsInternetEnabled, Converter={StaticResource BoolToVisibility}, ConverterParameter='#238636|#21262D'}" 
                                                                            BorderBrush="{Binding IsInternetEnabled, Converter={StaticResource BoolToVisibility}, ConverterParameter='#3FB950|#30363D'}" 
                                                                            BorderThickness="1" CornerRadius="4" Padding="8,4" x:Name="border">
                                                                        <TextBlock Text="🌐" FontSize="12" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="border" Property="Background" Value="#30363D"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                        
                                                        <!-- SMS Popup -->
                                                        <Popup IsOpen="{Binding IsSmsPopupOpen}" 
                                                               PlacementTarget="{Binding ElementName=SmsToggleButton}"
                                                               Placement="Bottom" StaysOpen="False"
                                                               AllowsTransparency="True">
                                                            <Border Background="#161B22" BorderBrush="#30363D" BorderThickness="1" 
                                                                    CornerRadius="8" Padding="8" MinWidth="280" MaxWidth="350" MaxHeight="300">
                                                                <Grid>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="*"/>
                                                                    </Grid.RowDefinitions>
                                                                    
                                                                    <!-- Header -->
                                                                    <Border Grid.Row="0" Background="#21262D" CornerRadius="4" Padding="8,6" Margin="0,0,0,8">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Grid.Column="0" Text="📬 الرسائل" FontSize="13" FontWeight="Bold" Foreground="#F0F6FC" VerticalAlignment="Center"/>
                                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                                                                <!-- Mark All Read Button -->
                                                                                <Button ToolTip="قراءة الكل" Margin="0,0,4,0"
                                                                                        Command="{Binding DataContext.MarkAllSmsReadCommand, Source={x:Reference Name=RootWindow}}"
                                                                                        CommandParameter="{Binding}">
                                                                                    <Button.Template>
                                                                                        <ControlTemplate TargetType="Button">
                                                                                            <Border Background="#238636" Padding="6,3" x:Name="btn" CornerRadius="3" Cursor="Hand">
                                                                                                <TextBlock Text="✓" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                                                                            </Border>
                                                                                            <ControlTemplate.Triggers>
                                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                                    <Setter TargetName="btn" Property="Background" Value="#2EA043"/>
                                                                                                </Trigger>
                                                                                            </ControlTemplate.Triggers>
                                                                                        </ControlTemplate>
                                                                                    </Button.Template>
                                                                                </Button>
                                                                                <!-- Delete All Button -->
                                                                                <Button ToolTip="حذف الكل" Margin="0,0,4,0"
                                                                                        Command="{Binding DataContext.DeleteModemSmsCommand, Source={x:Reference Name=RootWindow}}"
                                                                                        CommandParameter="{Binding}">
                                                                                    <Button.Template>
                                                                                        <ControlTemplate TargetType="Button">
                                                                                            <Border Background="#DA3633" Padding="6,3" x:Name="btn" CornerRadius="3" Cursor="Hand">
                                                                                                <TextBlock Text="🗑" FontSize="10" Foreground="White"/>
                                                                                            </Border>
                                                                                            <ControlTemplate.Triggers>
                                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                                    <Setter TargetName="btn" Property="Background" Value="#F85149"/>
                                                                                                </Trigger>
                                                                                            </ControlTemplate.Triggers>
                                                                                        </ControlTemplate>
                                                                                    </Button.Template>
                                                                                </Button>
                                                                                <!-- Refresh Button -->
                                                                                <Button ToolTip="تحديث الرسائل"
                                                                                        Command="{Binding DataContext.LoadModemSmsCommand, Source={x:Reference Name=RootWindow}}"
                                                                                        CommandParameter="{Binding}">
                                                                                    <Button.Template>
                                                                                        <ControlTemplate TargetType="Button">
                                                                                            <Border Background="Transparent" Padding="6,3" x:Name="btn" CornerRadius="3" Cursor="Hand">
                                                                                                <TextBlock Text="↻" FontSize="12" Foreground="#58A6FF"/>
                                                                                            </Border>
                                                                                            <ControlTemplate.Triggers>
                                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                                    <Setter TargetName="btn" Property="Background" Value="#30363D"/>
                                                                                                </Trigger>
                                                                                            </ControlTemplate.Triggers>
                                                                                        </ControlTemplate>
                                                                                    </Button.Template>
                                                                                </Button>
                                                                            </StackPanel>
                                                                        </Grid>
                                                                    </Border>
                                                                    
                                                                    <!-- Messages List -->
                                                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="220">
                                                                        <ItemsControl ItemsSource="{Binding SmsMessages}">
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <Button Command="{Binding DataContext.ShowSmsDetailCommand, Source={x:Reference Name=RootWindow}}"
                                                                                            CommandParameter="{Binding}" Cursor="Hand" Margin="0,2">
                                                                                        <Button.Template>
                                                                                            <ControlTemplate TargetType="Button">
                                                                                                <Border Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" 
                                                                                                        CornerRadius="6" Padding="10,8" x:Name="msgBorder">
                                                                                                    <Grid>
                                                                                                        <Grid.RowDefinitions>
                                                                                                            <RowDefinition Height="Auto"/>
                                                                                                            <RowDefinition Height="Auto"/>
                                                                                                        </Grid.RowDefinitions>
                                                                                                        <Grid.ColumnDefinitions>
                                                                                                            <ColumnDefinition Width="*"/>
                                                                                                            <ColumnDefinition Width="Auto"/>
                                                                                                        </Grid.ColumnDefinitions>
                                                                                                        
                                                                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding PhoneNumber}" 
                                                                                                                   FontSize="12" FontWeight="SemiBold" Foreground="#58A6FF"
                                                                                                                   FontFamily="Consolas" FlowDirection="LeftToRight"/>
                                                                                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}" 
                                                                                                                   FontSize="10" Foreground="#8B949E"/>
                                                                                                        
                                                                                                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2" 
                                                                                                                   Text="{Binding Message}" FontSize="14" Foreground="#C9D1D9"
                                                                                                                   TextTrimming="CharacterEllipsis" MaxWidth="300" Margin="0,4,0,0"/>
                                                                                                    </Grid>
                                                                                                </Border>
                                                                                                <ControlTemplate.Triggers>
                                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                                        <Setter TargetName="msgBorder" Property="Background" Value="#21262D"/>
                                                                                                        <Setter TargetName="msgBorder" Property="BorderBrush" Value="#58A6FF"/>
                                                                                                    </Trigger>
                                                                                                </ControlTemplate.Triggers>
                                                                                            </ControlTemplate>
                                                                                        </Button.Template>
                                                                                    </Button>
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>
                                                                    </ScrollViewer>
                                                                    
                                                                    <!-- Empty State -->
                                                                    <TextBlock Grid.Row="1" Text="لا توجد رسائل" FontSize="12" Foreground="#8B949E"
                                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                               Visibility="{Binding SmsMessages.Count, Converter={StaticResource InverseBoolToVisibility}}"/>
                                                                </Grid>
                                                            </Border>
                                                        </Popup>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left">
                                                        <Button ToolTip="إعادة تشغيل كاملة للمودم (Reset)" Cursor="Hand"
                                                                Command="{Binding DataContext.FullResetModemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="#DA3633" BorderBrush="#F85149" BorderThickness="1" 
                                                                            CornerRadius="4" Padding="10,4" x:Name="border">
                                                                        <TextBlock Text="Reset" FontSize="11" Foreground="White" VerticalAlignment="Center" FontWeight="Bold"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="border" Property="Background" Value="#F85149"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <Grid Grid.Row="1" Background="#0D1117">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Viewbox Width="40" Height="40">
                                                        <Grid>
                                                            <Ellipse Width="36" Height="36" Stroke="#30363D" StrokeThickness="3"/>
                                                            <Ellipse Width="36" Height="36" Stroke="#D29922" StrokeThickness="3"
                                                                     StrokeDashArray="2,2" RenderTransformOrigin="0.5,0.5">
                                                                <Ellipse.RenderTransform>
                                                                    <RotateTransform Angle="0"/>
                                                                </Ellipse.RenderTransform>
                                                                <Ellipse.Triggers>
                                                                    <EventTrigger RoutedEvent="Loaded">
                                                                        <BeginStoryboard>
                                                                            <Storyboard RepeatBehavior="Forever">
                                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                                               From="0" To="360" Duration="0:0:1"/>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </EventTrigger>
                                                                </Ellipse.Triggers>
                                                            </Ellipse>
                                                        </Grid>
                                                    </Viewbox>
                                                </Grid>

                                                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="8,6">
                                                    <ScrollViewer.Style>
                                                        <Style TargetType="ScrollViewer">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ScrollViewer.Style>
                                                    <TextBlock Text="{Binding LastResponse}" 
                                                               FontSize="16" Foreground="#3FB950" 
                                                               TextWrapping="Wrap" FlowDirection="LeftToRight"
                                                               FontFamily="Consolas">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#3FB950"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="فشل">
                                                                        <Setter Property="Foreground" Value="#F85149"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </ScrollViewer>

                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="💬 الرسائل SMS" Style="{StaticResource TabItemStyle}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardPanel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Text="{Binding SmsPhoneNumber, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource ModernTextBox}" 
                                     FlowDirection="LeftToRight"/>
                            
                            <TextBlock Grid.Column="1" Text="الرقم:" Foreground="#8B949E" 
                                       VerticalAlignment="Center" Margin="12,0" FontSize="13"/>

                            <TextBox Grid.Column="2" Text="{Binding SmsMessage, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource ModernTextBox}"
                                     AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="80"/>

                            <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="12,0,0,0">
                                <Button Content="📤 إرسال" Command="{Binding SendSmsCommand}" Style="{StaticResource ModernButton}"
                                        IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}"/>
                                <Button Content="📥 جلب الرسائل" Command="{Binding GetSmsCommand}" Style="{StaticResource BlueButton}"
                                        IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}"/>
                                <Button Content="🗑 حذف الكل" Command="{Binding DeleteAllSmsCommand}" Style="{StaticResource RedButton}"
                                        IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource CardPanel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="📨" FontSize="18" Margin="0,0,8,0"/>
                                <TextBlock Text="الرسائل الواردة" FontSize="16" FontWeight="Bold" Foreground="#F0F6FC"/>
                            </StackPanel>

                            <ListView Grid.Row="1" ItemsSource="{Binding SmsMessages}" 
                                      Background="Transparent" BorderThickness="0">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListViewItem">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="12" Padding="0" Margin="0,6"
                                                BorderBrush="#30363D" BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#21262D"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasOtp}" Value="True">
                                                            <Setter Property="BorderBrush" Value="#238636"/>
                                                            <Setter Property="BorderThickness" Value="2"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                
                                                <!-- OTP Display (Large and Prominent) -->
                                                <Border Grid.Row="0" Background="#0D2818" CornerRadius="12,12,0,0" Padding="16,12"
                                                        Visibility="{Binding ExtractedOtp, Converter={StaticResource OtpTextVisibilityConverter}}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="🔐" FontSize="28" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="رمز التحقق OTP" FontSize="14" Foreground="#8B949E" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding ExtractedOtp}" FontSize="32" FontWeight="Bold" 
                                                                       Foreground="#3FB950" FontFamily="Consolas"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="2" Content="📋 نسخ" Style="{StaticResource ModernButton}" 
                                                                Padding="12,8" VerticalAlignment="Center"
                                                                Tag="{Binding ExtractedOtp}"
                                                                Click="CopyOtpButton_Click"/>
                                                    </Grid>
                                                </Border>
                                                
                                                <!-- Message Header -->
                                                <Border Grid.Row="1" Background="#161B22" Padding="14,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="📱" FontSize="14" Margin="0,0,6,0"/>
                                                                <TextBlock Text="{Binding ModemPhoneNumber}" FontSize="15" FontWeight="Bold" Foreground="#58A6FF"/>
                                                                <TextBlock Text=" ← " FontSize="12" Foreground="#484F58"/>
                                                                <TextBlock Text="{Binding PhoneNumber}" FontSize="13" Foreground="#8B949E"/>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding Timestamp, StringFormat='dd/MM/yyyy hh:mm tt'}" 
                                                                       FontSize="11" Foreground="#484F58" Margin="22,4,0,0"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="1" CornerRadius="6" Padding="10,5" VerticalAlignment="Top">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#1F6FEB"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Unread">
                                                                            <Setter Property="Background" Value="#238636"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding Status}" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                
                                                <!-- Message Content -->
                                                <Border Grid.Row="2" Background="#21262D" Padding="14,12" CornerRadius="0,0,12,12">
                                                    <TextBlock FontSize="16" Foreground="#C9D1D9" TextWrapping="Wrap" LineHeight="26">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="{Binding Message}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasOtp}" Value="True">
                                                                        <Setter Property="Text" Value="{Binding MessageWithoutOtp}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>


            <!-- Orange Cash Tab -->
            <TabItem Header="💰 أورانج كاش" Style="{StaticResource OrangeTabItem}">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="380"/>
                    </Grid.ColumnDefinitions>

                    <!-- Modem Grid -->
                    <Border Grid.Column="0" Style="{StaticResource CardPanel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="📱" FontSize="18" Margin="0,0,8,0"/>
                                <TextBlock Text="المودمات" FontSize="16" FontWeight="Bold" Foreground="#F0F6FC"/>
                                <Button Content="📋 إعداد الأزواج" Command="{Binding SetupSenderReceiverPairsCommand}" 
                                        Style="{StaticResource BlueButton}" Margin="20,0,0,0" Padding="12,6"/>
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Modems}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="4" Rows="3"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="4" Background="#0D1117" BorderThickness="2" CornerRadius="8">
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="🔄 إعادة تشغيل المودم" 
                                                                  Command="{Binding DataContext.RestartModemCommand, Source={x:Reference Name=RootWindow}}"
                                                                  CommandParameter="{Binding}"/>
                                                        <MenuItem Header="📋 نسخ الرقم" 
                                                                  Command="{Binding DataContext.CopyPhoneNumberCommand, Source={x:Reference Name=RootWindow}}"
                                                                  CommandParameter="{Binding}"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="BorderBrush" Value="#30363D"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSenderLine}" Value="True">
                                                                <Setter Property="BorderBrush" Value="#F78166"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsReceiverLine}" Value="True">
                                                                <Setter Property="BorderBrush" Value="#3FB950"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding TransferStatus}" Value="تم التحويل ✓">
                                                                <Setter Property="Background" Value="#0F2A1C"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding TransferStatus}" Value="تم الاستلام ✓">
                                                                <Setter Property="Background" Value="#0F2A1C"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Header with Phone & Balance -->
                                                    <Border Grid.Row="0" Padding="8,6" CornerRadius="6,6,0,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#161B22"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSenderLine}" Value="True">
                                                                        <Setter Property="Background" Value="#3D1F13"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsReceiverLine}" Value="True">
                                                                        <Setter Property="Background" Value="#132A1F"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                                                       Text="{Binding Index, StringFormat='#{0}'}" 
                                                                       FontSize="12" FontWeight="Bold" Foreground="#58A6FF"
                                                                       Margin="0,0,8,0"/>
                                                            <TextBlock Grid.Row="0" Grid.Column="1" 
                                                                       Text="{Binding DisplayName}" 
                                                                       FontSize="13" FontWeight="Bold" Foreground="#F0F6FC"
                                                                       FlowDirection="LeftToRight"/>
                                                            
                                                            <TextBlock Grid.Row="1" Grid.ColumnSpan="2" 
                                                                       Text="{Binding DisplayBalance}" 
                                                                       FontSize="11" Foreground="#8B949E"
                                                                       FlowDirection="LeftToRight"/>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Status Content -->
                                                    <StackPanel Grid.Row="1" Margin="8">
                                                        <Border CornerRadius="4" Padding="6,3" Margin="0,0,0,4" HorizontalAlignment="Left">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#21262D"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSenderLine}" Value="True">
                                                                            <Setter Property="Background" Value="#F78166"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsReceiverLine}" Value="True">
                                                                            <Setter Property="Background" Value="#238636"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock FontSize="11" Foreground="White">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="-"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsSenderLine}" Value="True">
                                                                                <Setter Property="Text" Value="📤 مرسل"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding IsReceiverLine}" Value="True">
                                                                                <Setter Property="Text" Value="📥 مستلم"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>

                                                        <TextBlock Text="{Binding TransferStatus}" 
                                                                   FontSize="12" FontWeight="Bold" Margin="0,4">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#C9D1D9"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding TransferStatus}" Value="تم التحويل ✓">
                                                                            <Setter Property="Foreground" Value="#3FB950"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding TransferStatus}" Value="تم الاستلام ✓">
                                                                            <Setter Property="Foreground" Value="#3FB950"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>

                                                        <TextBlock Text="{Binding ConfirmationMessage}" 
                                                                   FontSize="10" Foreground="#8B949E" 
                                                                   TextWrapping="Wrap" Margin="0,2"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Control Panel -->
                    <Border Grid.Column="1" Style="{StaticResource CardPanel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="💰" FontSize="24" Margin="0,0,10,0"/>
                                <TextBlock Text="أورانج كاش" FontSize="20" FontWeight="Bold" Foreground="#F78166"/>
                            </StackPanel>

                            <!-- Settings -->
                            <StackPanel Grid.Row="1">
                                <TextBlock Text="رقم المرسل الأساسي:" Foreground="#F78166" FontSize="13" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding PrimarySenderPhone, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource ModernTextBox}" 
                                         FontFamily="Consolas" FontSize="16"
                                         FlowDirection="LeftToRight" Margin="0,0,0,12"/>
                                <TextBlock Text="(رقم الهاتف للمودم المرسل - جميع المودمات الأخرى ستكون مستلمين)" Foreground="#6E7681" FontSize="11" Margin="0,-8,0,12"/>

                                <TextBlock Text="المبلغ:" Foreground="#8B949E" FontSize="13" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding TransferAmount, UpdateSourceTrigger=PropertyChanged}" 
                                             Style="{StaticResource ModernTextBox}" 
                                             FontFamily="Consolas" FontSize="16"
                                             FlowDirection="LeftToRight"/>
                                    <TextBlock Grid.Column="1" Text="ج.م" Foreground="#8B949E" 
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                                    <Button Content="💰 استعلام الأرصدة" 
                                            Command="{Binding QueryOrangeCashBalancesCommand}" 
                                            Style="{StaticResource BlueButton}" 
                                            Padding="16,10"
                                            IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}"/>
                                </StackPanel>

                                <Button Content="🚀 بدء التحويل المتوازي" 
                                        Command="{Binding ExecuteParallelTransfersCommand}" 
                                        FontSize="16" Padding="20,14"
                                        HorizontalAlignment="Stretch"
                                        IsEnabled="{Binding IsTransferRunning, Converter={StaticResource InverseBoolConverter}}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource OrangeButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTransferRunning}" Value="True">
                                                    <Setter Property="Background" Value="#484F58"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Content="⛔ إيقاف" 
                                        Command="{Binding StopTransfersCommand}" 
                                        Style="{StaticResource RedButton}" 
                                        HorizontalAlignment="Stretch" Margin="0,8,0,0"
                                        Visibility="{Binding IsTransferRunning, Converter={StaticResource BoolToVisibility}}"/>

                                <!-- Cooldown Display -->
                                <Border Background="#21262D" CornerRadius="8" Padding="12" Margin="0,12,0,0"
                                        Visibility="{Binding IsCooldownActive, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="⏱️ انتظار" FontSize="14" Foreground="#D29922" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding CooldownSeconds, StringFormat='{}{0} ثانية'}" 
                                                   FontSize="24" FontWeight="Bold" Foreground="#F78166" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Stats -->
                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#238636" CornerRadius="8" Padding="12" Margin="0,0,4,0">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding SuccessfulTransfers}" FontSize="28" 
                                                       FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                            <TextBlock Text="نجح" FontSize="12" Foreground="#C9D1D9" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Background="#DA3633" CornerRadius="8" Padding="12" Margin="4,0,0,0">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding FailedTransfers}" FontSize="28" 
                                                       FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                            <TextBlock Text="فشل" FontSize="12" Foreground="#C9D1D9" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>

                            <!-- Log -->
                            <Border Grid.Row="2" Background="#0D1117" CornerRadius="8" Margin="0,16,0,0" Padding="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="📋 سجل العمليات" FontSize="13" Foreground="#8B949E" VerticalAlignment="Center"/>
                                        <Button Content="📖 عرض السجل" Command="{Binding ShowParallelTransferLogCommand}" 
                                                Style="{StaticResource BlueButton}" Padding="10,4" Margin="12,0,0,0" FontSize="11"/>
                                        <Button Content="🗑" Command="{Binding ClearTransferLogCommand}" 
                                                Style="{StaticResource GhostButton}" Padding="4,2" Margin="8,0,0,0"
                                                ToolTip="مسح السجل"/>
                                    </StackPanel>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <ItemsControl ItemsSource="{Binding TransferLogEntries}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,2" Padding="8,4" CornerRadius="4" 
                                                                Background="#161B22" BorderThickness="1"
                                                                BorderBrush="{Binding IsSuccess, Converter={StaticResource TransferStatusToColorConverter}}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" 
                                                                           Text="{Binding PhoneNumber}" 
                                                                           FontSize="12" FontWeight="Bold" 
                                                                           Foreground="{Binding IsSuccess, Converter={StaticResource TransferStatusToColorConverter}}"
                                                                           Margin="0,0,12,0" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="1" 
                                                                           Text="{Binding Message}" 
                                                                           FontSize="14" 
                                                                           Foreground="#8B949E"
                                                                           TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="2" 
                                                                           Text="{Binding StatusIcon}" 
                                                                           FontSize="14" FontWeight="Bold"
                                                                           Foreground="{Binding IsSuccess, Converter={StaticResource TransferStatusToColorConverter}}"
                                                                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Text="{Binding TransferLog}" FontSize="15" 
                                                       Foreground="#3FB950" FontFamily="Consolas"
                                                       TextWrapping="Wrap" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- OC Series Tab - تحويل متسلسل -->
            <TabItem Header="🔄 OC متسلسل" Style="{StaticResource OrangeTabItem}">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="400"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Panel - Modem Selection -->
                    <Border Grid.Column="0" Style="{StaticResource CardPanel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="📱" FontSize="18" Margin="0,0,8,0"/>
                                <TextBlock Text="اختر المودمات المستلمة (غير الأساسي)" FontSize="16" FontWeight="Bold" Foreground="#F0F6FC"/>
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Modems}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="4" Background="#0D1117" CornerRadius="6" Padding="12,8" MinWidth="200">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="BorderBrush" Value="#30363D"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMainLine}" Value="True">
                                                                <Setter Property="BorderBrush" Value="#F0883E"/>
                                                                <Setter Property="BorderThickness" Value="2"/>
                                                                <Setter Property="Background" Value="#1C1F24"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <StackPanel Grid.Column="1">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding PhoneNumber}" FontSize="14" FontWeight="Bold"
                                                                       Foreground="{Binding Operator, Converter={StaticResource OperatorToBrushConverter}}"
                                                                       FontFamily="Consolas" FlowDirection="LeftToRight"/>
                                                            <TextBlock Text=" ⭐" FontSize="12" Foreground="#F0883E"
                                                                       Visibility="{Binding IsMainLine, Converter={StaticResource BoolToVisibility}}"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding PortName}" FontSize="11" Foreground="#8B949E"/>
                                                        <TextBlock Text="{Binding TransferStatus}" FontSize="10" Foreground="#3FB950" 
                                                                   Visibility="{Binding TransferStatus, Converter={StaticResource StringToVisibility}}"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="2" Content="تعيين أساسي" 
                                                            Command="{Binding DataContext.SetMainLineCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource GhostButton}" FontSize="10" Padding="6,4"
                                                            Visibility="{Binding IsMainLine, Converter={StaticResource InverseBoolToVisibility}}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Right Panel - Settings & Log -->
                    <Border Grid.Column="1" Style="{StaticResource CardPanel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="🔗" FontSize="24" Margin="0,0,10,0"/>
                                <TextBlock Text="تحويل متسلسل (Chain)" FontSize="20" FontWeight="Bold" Foreground="#58A6FF"/>
                            </StackPanel>

                            <!-- Settings -->
                            <StackPanel Grid.Row="1">
                                <!-- Main Line Section -->
                                <Border Background="#21262D" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="📱 الخط الأساسي" FontSize="14" FontWeight="Bold" Foreground="#F0883E" Margin="0,0,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontSize="16" FontWeight="Bold" Foreground="#F0F6FC" FontFamily="Consolas" FlowDirection="LeftToRight">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="لم يتم التعيين"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsMainLineSet}" Value="True">
                                                                    <Setter Property="Text" Value="{Binding MainLineModem.PhoneNumber}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="{Binding MainLineModem.PortName}" FontSize="11" Foreground="#8B949E"
                                                           Visibility="{Binding IsMainLineSet, Converter={StaticResource BoolToVisibility}}"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="❌" Command="{Binding ClearMainLineCommand}" 
                                                    Style="{StaticResource GhostButton}" Padding="6,4" FontSize="12"
                                                    Visibility="{Binding IsMainLineSet, Converter={StaticResource BoolToVisibility}}"
                                                    ToolTip="إلغاء تعيين الأساسي"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Balance Section -->
                                <Border Background="#0D1117" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="💰 رصيد الأساسي" FontSize="12" Foreground="#8B949E"/>
                                            <TextBlock Text="{Binding MainLineBalance, StringFormat='{}{0:N2} ج.م'}" 
                                                       FontSize="24" FontWeight="Bold" Foreground="#3FB950" FontFamily="Consolas"/>
                                            <TextBlock Text="{Binding MainLineRemainingBalance, StringFormat='المتبقي: {0:N2} ج.م'}" 
                                                       FontSize="12" Foreground="#D29922"
                                                       Visibility="{Binding IsOcSeriesRunning, Converter={StaticResource BoolToVisibility}}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="🔍 استعلام" Command="{Binding QueryMainLineBalanceCommand}" 
                                                Style="{StaticResource BlueButton}" Padding="12,8" FontSize="12"
                                                IsEnabled="{Binding IsMainLineSet}"/>
                                    </Grid>
                                </Border>

                                <!-- Transfer Settings -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,6,0">
                                        <TextBlock Text="المتبقي لكل مودم:" Foreground="#8B949E" FontSize="13" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding RemainingPerModem, UpdateSourceTrigger=PropertyChanged}" 
                                                 Style="{StaticResource ModernTextBox}" FontFamily="Consolas" FontSize="14"
                                                 FlowDirection="LeftToRight"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                        <TextBlock Text="تأخير (ثانية):" Foreground="#8B949E" FontSize="13" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding OcSeriesDelay, UpdateSourceTrigger=PropertyChanged}" 
                                                 Style="{StaticResource ModernTextBox}" FontFamily="Consolas" FontSize="14"
                                                 FlowDirection="LeftToRight"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Total Calculation -->
                                <Border Background="#161B22" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="📊 حساب التحويل" FontSize="12" Foreground="#8B949E" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding ChainedTransferTotal, StringFormat='إجمالي التحويل: {0} ج.م'}" 
                                                   FontSize="16" FontWeight="Bold" Foreground="#58A6FF"/>
                                    </StackPanel>
                                </Border>

                                <!-- Countdown Display -->
                                <Border Background="#21262D" CornerRadius="8" Padding="12" Margin="0,0,0,12"
                                        Visibility="{Binding IsOcSeriesRunning, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="⏱️ انتظار" FontSize="14" Foreground="#D29922" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding OcSeriesCountdown, StringFormat='{}{0} ثانية'}" 
                                                   FontSize="24" FontWeight="Bold" Foreground="#58A6FF" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Button Content="🔗 بدء التحويل المتسلسل" 
                                        Command="{Binding StartChainedTransferCommand}" 
                                        FontSize="16" Padding="20,14" HorizontalAlignment="Stretch"
                                        IsEnabled="{Binding IsOcSeriesRunning, Converter={StaticResource InverseBoolConverter}}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource BlueButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOcSeriesRunning}" Value="True">
                                                    <Setter Property="Background" Value="#484F58"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Content="⛔ إيقاف" Command="{Binding StopOcSeriesCommand}" 
                                        Style="{StaticResource RedButton}" HorizontalAlignment="Stretch" Margin="0,8,0,0"
                                        Visibility="{Binding IsOcSeriesRunning, Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>

                            <!-- Log -->
                            <Border Grid.Row="2" Background="#0D1117" CornerRadius="8" Margin="0,12,0,0" Padding="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="📋 سجل التحويلات" FontSize="13" Foreground="#8B949E"/>
                                        <Button Content="🗑" Command="{Binding ClearOcSeriesLogCommand}" 
                                                Style="{StaticResource GhostButton}" Padding="4,2" Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <TextBlock Text="{Binding OcSeriesLog}" FontSize="15" 
                                                   Foreground="#3FB950" FontFamily="Consolas" TextWrapping="Wrap"/>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Custom Orange Transfer Tab - تحويل مخصص -->
            <TabItem Header="📊 تحويل TXT" Style="{StaticResource OrangeTabItem}">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="380"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Panel - Transfer List -->
                    <Border Grid.Column="0" Style="{StaticResource CardPanel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="📄" FontSize="18" Margin="0,0,8,0"/>
                                <TextBlock Text="قائمة التحويلات" FontSize="16" FontWeight="Bold" Foreground="#F0F6FC"/>
                                <Button Content="📂 استيراد" Command="{Binding ImportExcelCommand}" 
                                        Style="{StaticResource OrangeButton}" Margin="12,0,0,0" Padding="8,4" FontSize="12"/>
                                <Button Content="🗑 مسح" Command="{Binding ClearExcelTransfersCommand}" 
                                        Style="{StaticResource RedButton}" Margin="4,0,0,0" Padding="8,4" FontSize="12"/>
                                <Button Content="✅ تصدير ناجح" Command="{Binding ExportSuccessfulCommand}" 
                                        Style="{StaticResource GreenButton}" Margin="8,0,0,0" Padding="8,4" FontSize="12"/>
                                <Button Content="❌ تصدير فاشل" Command="{Binding ExportFailedCommand}" 
                                        Style="{StaticResource RedButton}" Margin="4,0,0,0" Padding="8,4" FontSize="12"/>
                            </StackPanel>

                            <!-- Summary Section -->
                            <Border Grid.Row="1" Background="#1A0F00" BorderBrush="#FF7900" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="📋 عدد الأرقام" FontSize="12" Foreground="#8B949E" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding TxtTransferCount}" FontSize="24" FontWeight="Bold" 
                                                   Foreground="#FF7900" HorizontalAlignment="Center" FontFamily="Consolas"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock Text="💰 المبلغ لكل رقم" FontSize="12" Foreground="#8B949E" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding FixedTransferAmount, StringFormat='{}{0} ج.م'}" FontSize="24" FontWeight="Bold" 
                                                   Foreground="#3FB950" HorizontalAlignment="Center" FontFamily="Consolas"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock Text="📊 الإجمالي المطلوب" FontSize="12" Foreground="#8B949E" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding TxtTransferTotal, StringFormat='{}{0} ج.م'}" FontSize="24" FontWeight="Bold" 
                                                   Foreground="#58A6FF" HorizontalAlignment="Center" FontFamily="Consolas"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                        <TextBlock Text="💵 رصيد الكاش" FontSize="12" Foreground="#8B949E" HorizontalAlignment="Center"/>
                                        <TextBlock FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" FontFamily="Consolas">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding SenderCashBalanceRemaining, StringFormat='{}{0} ج.م'}"/>
                                                    <Setter Property="Foreground" Value="#3FB950"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCashBalanceQueried}" Value="False">
                                                            <Setter Property="Text" Value="--"/>
                                                            <Setter Property="Foreground" Value="#8B949E"/>
                                                        </DataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsCashBalanceQueried}" Value="True"/>
                                                                <Condition Binding="{Binding SenderCashBalanceRemaining}" Value="0"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Foreground" Value="#DA3633"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <DataGrid Grid.Row="2" ItemsSource="{Binding ExcelTransferItems}" 
                                      AutoGenerateColumns="False" Background="Transparent" 
                                      BorderThickness="0" CanUserAddRows="False" CanUserDeleteRows="False"
                                      GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                      RowBackground="#000000" AlternatingRowBackground="#0D0D0D"
                                      Foreground="#C9D1D9"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.CanContentScroll="True"
                                      EnableRowVirtualization="True">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#1A1A1A"/>
                                        <Setter Property="Foreground" Value="#8B949E"/>
                                        <Setter Property="Padding" Value="12,8"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="#000000"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                                <Setter Property="Background" Value="#0D2818"/>
                                                <Setter Property="Foreground" Value="#3FB950"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsFailed}" Value="True">
                                                <Setter Property="Background" Value="#2D0F0F"/>
                                                <Setter Property="Foreground" Value="#F85149"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="40" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="رقم الهاتف" Binding="{Binding PhoneNumber}" Width="130" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="المبلغ" Binding="{Binding Amount}" Width="60" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="الحالة" Binding="{Binding Status}" Width="100" IsReadOnly="True"/>
                                    <DataGridTemplateColumn Header="رد الشبكة" Width="*" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding NetworkResponse}" 
                                                           Foreground="{Binding NetworkResponseColor}" 
                                                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding NetworkResponse}" FontSize="12"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="محاولات" Binding="{Binding RetryCount}" Width="60" IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- Right Panel - Settings & Log -->
                    <Border Grid.Column="1" Style="{StaticResource CardPanel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="📄" FontSize="24" Margin="0,0,10,0"/>
                                <TextBlock Text="تحويل من TXT" FontSize="20" FontWeight="Bold" Foreground="#FF7900"/>
                            </StackPanel>

                            <!-- Settings -->
                            <StackPanel Grid.Row="1">
                                <!-- Multiple Senders Section -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="الأرقام المرسلة:" Foreground="#8B949E" FontSize="13" VerticalAlignment="Center"/>
                                    <Button Content="➕" Command="{Binding AddSenderLineCommand}" 
                                            Style="{StaticResource ModernButton}" Padding="8,4" Margin="12,0,0,0" FontSize="14"
                                            ToolTip="إضافة مرسل جديد"/>
                                </StackPanel>
                                
                                <!-- Sender Lines List -->
                                <ItemsControl ItemsSource="{Binding SenderLines}" Margin="0,0,0,12">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#161B22" CornerRadius="6" Padding="8" Margin="0,0,0,6" BorderBrush="#FF7900" BorderThickness="1">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <TextBlock Text="{Binding Index, StringFormat='#{0}'}" FontSize="14" FontWeight="Bold" 
                                                               Foreground="#FF7900" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    
                                                    <ComboBox Grid.Column="1" ItemsSource="{Binding DataContext.Modems, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                              SelectedItem="{Binding SelectedModem}"
                                                              DisplayMemberPath="DisplayName"
                                                              Background="#FFFFFF" Foreground="#1A1A1A" BorderBrush="#FF7900" BorderThickness="1"
                                                              FontSize="13" FontWeight="SemiBold" Padding="6,4">
                                                        <ComboBox.Resources>
                                                            <Style TargetType="ComboBoxItem">
                                                                <Setter Property="Background" Value="#FFFFFF"/>
                                                                <Setter Property="Foreground" Value="#1A1A1A"/>
                                                                <Setter Property="Padding" Value="8,6"/>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#FFE5CC"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Setter Property="Background" Value="#FF7900"/>
                                                                        <Setter Property="Foreground" Value="#FFFFFF"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ComboBox.Resources>
                                                    </ComboBox>
                                                    
                                                    <Button Grid.Column="2" Content="✕" 
                                                            Command="{Binding DataContext.RemoveSenderLineCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource RedButton}" Padding="6,2" FontSize="12"
                                                            ToolTip="حذف المرسل"/>
                                                    
                                                    <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,4,0,0">
                                                        <TextBlock Text="💰" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                        <TextBlock Text="{Binding CashBalanceDisplay}" FontSize="12" FontWeight="Bold" 
                                                                   Foreground="#3FB950" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                        <TextBlock Text="{Binding Status}" FontSize="11" 
                                                                   Foreground="#8B949E" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                
                                <Button Content="💰 استعلام الكاش" 
                                        Command="{Binding QuerySenderCashBalanceCommand}" 
                                        Style="{StaticResource BlueButton}" Padding="12,6" Margin="0,0,0,12" HorizontalAlignment="Stretch"
                                        IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}"/>

                                <!-- Fixed Amount Section -->
                                <Border Background="#0D0D0D" CornerRadius="8" Padding="12" Margin="0,0,0,12" BorderBrush="#FF7900" BorderThickness="1">
                                    <StackPanel>
                                        <CheckBox IsChecked="{Binding UseFixedAmount}" Content="استخدام مبلغ موحد لجميع الأرقام" 
                                                  Foreground="#F0F6FC" FontSize="13" Margin="0,0,0,8"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="المبلغ لكل سطر:" Foreground="#8B949E" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBox Text="{Binding FixedTransferAmount, UpdateSourceTrigger=PropertyChanged}" 
                                                     Style="{StaticResource ModernTextBox}" FontFamily="Consolas" FontSize="16" 
                                                     FontWeight="Bold" Width="100"
                                                     FlowDirection="LeftToRight" IsEnabled="{Binding UseFixedAmount}"/>
                                            <TextBlock Text="ج.م" Foreground="#FF7900" FontSize="14" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="تأخير بين التحويلات (ثانية):" Foreground="#8B949E" FontSize="13" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding CustomTransferDelay, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource ModernTextBox}" FontFamily="Consolas" FontSize="14"
                                         FlowDirection="LeftToRight" Margin="0,0,0,16"/>

                                <!-- Progress Display -->
                                <Border Background="#1A0F00" CornerRadius="8" Padding="12" Margin="0,0,0,12"
                                        Visibility="{Binding IsCustomTransferRunning, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock FontSize="14" Foreground="#FF7900" HorizontalAlignment="Center">
                                            <Run Text="📊 التقدم: "/>
                                            <Run Text="{Binding TxtTransferCompleted}"/>
                                            <Run Text="/"/>
                                            <Run Text="{Binding TxtTransferCount}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding TxtTransferTimeRemaining, StringFormat='⏱️ الوقت المتبقي: {0}'}" 
                                                   FontSize="20" FontWeight="Bold" Foreground="#3FB950" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                        <TextBlock Text="{Binding CustomTransferCountdown, StringFormat='⏳ انتظار: {0} ثانية'}" 
                                                   FontSize="16" Foreground="#FF7900" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Button Content="🚀 بدء التحويل" 
                                        Command="{Binding StartCustomTransferCommand}" 
                                        FontSize="16" Padding="20,14" HorizontalAlignment="Stretch"
                                        IsEnabled="{Binding IsCustomTransferRunning, Converter={StaticResource InverseBoolConverter}}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource OrangeButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCustomTransferRunning}" Value="True">
                                                    <Setter Property="Background" Value="#484F58"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Content="⛔ إيقاف" Command="{Binding StopCustomTransferCommand}" 
                                        Style="{StaticResource RedButton}" HorizontalAlignment="Stretch" Margin="0,8,0,0"
                                        Visibility="{Binding IsCustomTransferRunning, Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>

                            <!-- Log -->
                            <Border Grid.Row="2" Background="#000000" CornerRadius="8" Margin="0,16,0,0" Padding="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="📋 سجل التحويلات" FontSize="13" Foreground="#8B949E" VerticalAlignment="Center"/>
                                        <Button Content="📖 عرض السجل" Command="{Binding ShowTransferLogCommand}" 
                                                Style="{StaticResource BlueButton}" Padding="10,4" Margin="12,0,0,0" FontSize="11"/>
                                    </StackPanel>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <ItemsControl ItemsSource="{Binding CustomTransferLogEntries}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,2" Padding="8,4" CornerRadius="4" 
                                                                Background="#161B22" BorderThickness="1"
                                                                BorderBrush="{Binding IsSuccess, Converter={StaticResource TransferStatusToColorConverter}}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" 
                                                                           Text="{Binding PhoneNumber}" 
                                                                           FontSize="12" FontWeight="Bold" 
                                                                           Foreground="{Binding IsSuccess, Converter={StaticResource TransferStatusToColorConverter}}"
                                                                           Margin="0,0,12,0" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="1" 
                                                                           Text="{Binding Message}" 
                                                                           FontSize="14" 
                                                                           Foreground="#8B949E"
                                                                           TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="2" 
                                                                           Text="{Binding StatusIcon}" 
                                                                           FontSize="14" FontWeight="Bold"
                                                                           Foreground="{Binding IsSuccess, Converter={StaticResource TransferStatusToColorConverter}}"
                                                                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Text="{Binding CustomTransferLog}" FontSize="15" 
                                                       Foreground="#3FB950" FontFamily="Consolas" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="📊 الإحصائيات" Style="{StaticResource TabItemStyle}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardPanel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Background="#238636" CornerRadius="8" Padding="20" Margin="4">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding SuccessfulCommandsCount}" FontSize="36" FontWeight="Bold" 
                                               Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="أوامر ناجحة" FontSize="14" Foreground="#C9D1D9" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Background="#DA3633" CornerRadius="8" Padding="20" Margin="4">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding FailedCommandsCount}" FontSize="36" FontWeight="Bold" 
                                               Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="أوامر فاشلة" FontSize="14" Foreground="#C9D1D9" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="#1F6FEB" CornerRadius="8" Padding="20" Margin="4">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding ConnectedCount}" FontSize="36" FontWeight="Bold" 
                                               Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="مودمات متصلة" FontSize="14" Foreground="#C9D1D9" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="3" Background="#D29922" CornerRadius="8" Padding="20" Margin="4">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding TotalSmsCount}" FontSize="36" FontWeight="Bold" 
                                               Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="رسائل" FontSize="14" Foreground="#C9D1D9" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource CardPanel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="📜" FontSize="18" Margin="0,0,8,0"/>
                                <TextBlock Text="سجل الأوامر" FontSize="16" FontWeight="Bold" Foreground="#F0F6FC"/>
                            </StackPanel>

                            <ListView Grid.Row="1" ItemsSource="{Binding CommandHistory}" 
                                      Background="Transparent" BorderThickness="0">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListViewItem">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="8" Padding="14" Margin="0,4" BorderThickness="2,0,0,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#21262D"/>
                                                    <Setter Property="BorderBrush" Value="#30363D"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                                            <Setter Property="BorderBrush" Value="#3FB950"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                                            <Setter Property="BorderBrush" Value="#F85149"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding ModemIndex, StringFormat='مودم {0}'}" 
                                                                   FontSize="13" FontWeight="Bold" Foreground="#F0F6FC"/>
                                                        <Border Background="#0D419D" CornerRadius="4" Padding="6,2" Margin="10,0,0,0">
                                                            <TextBlock Text="{Binding Command}" FontSize="11" Foreground="#58A6FF"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Response}" FontSize="12" 
                                                               Foreground="#8B949E" TextWrapping="Wrap" Margin="0,6,0,0"
                                                               MaxWidth="500" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding ExecutionTime.TotalSeconds, StringFormat='{}{0:F1}s'}" 
                                                               FontSize="12" Foreground="#58A6FF"/>
                                                    <TextBlock Text="{Binding Timestamp, StringFormat='hh:mm:ss tt'}" 
                                                               FontSize="10" Foreground="#484F58" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="📝 USSD متسلسل" Style="{StaticResource TabItemStyle}">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,6,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock Text="📝" FontSize="18" Margin="0,0,8,0"/>
                                    <TextBlock Text="تنفيذ أوامر USSD متسلسلة على كل المودمات" FontSize="16" FontWeight="Bold" Foreground="#F0F6FC"/>
                                </StackPanel>

                                <TextBlock Text="يتم تنفيذ كل أمر على جميع المودمات المحددة في لوحة التحكم" 
                                           Foreground="#8B949E" FontSize="12" Margin="0,0,0,12" TextWrapping="Wrap"/>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="التأخير بين المودمات:" Foreground="#8B949E" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding SequentialDelayMs}" 
                                             Style="{StaticResource ModernTextBox}" Width="80" Margin="10,0,0,0"/>
                                    <TextBlock Grid.Column="2" Text="مللي ثانية" Foreground="#8B949E" 
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>

                                <Border Background="#0D419D" CornerRadius="6" Padding="10" Margin="0,0,0,12"
                                        Visibility="{Binding CurrentSequentialCommand, Converter={StaticResource StringToVisibility}}">
                                    <TextBlock Text="{Binding CurrentSequentialCommand}" Foreground="#F0F6FC" 
                                               FontSize="13" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>

                            <Border Grid.Row="1" Background="#21262D" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="إضافة أمر USSD:" Foreground="#F0F6FC" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBox Text="{Binding NewSequentialCommand, UpdateSourceTrigger=PropertyChanged}" 
                                                 Style="{StaticResource ModernTextBox}"
                                                 FlowDirection="LeftToRight"/>
                                        <Button Grid.Column="1" Content="➕ إضافة" 
                                                Command="{Binding AddSequentialCommandCommand}"
                                                Style="{StaticResource ModernButton}"
                                                IsEnabled="{Binding IsSequentialRunning, Converter={StaticResource InverseBoolConverter}}"/>
                                        <CheckBox Grid.Row="1" Grid.ColumnSpan="2"
                                                  IsChecked="{Binding NewCommandIsReply}" 
                                                  Content="رد في نفس الجلسة (Reply)" 
                                                  Foreground="#8B949E" 
                                                  Margin="0,8,0,0"
                                                  ToolTip="حدد هذا الخيار إذا كان الأمر رداً على أمر USSD سابق في نفس الجلسة"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Background="#0D1117" CornerRadius="6" BorderBrush="#30363D" BorderThickness="1" Padding="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="قائمة الأوامر:" Foreground="#8B949E" FontSize="12" Margin="0,0,0,8"/>
                                    <ListView Grid.Row="1" ItemsSource="{Binding SequentialCommands}" 
                                              Background="Transparent" BorderThickness="0"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#161B22" CornerRadius="4" Padding="10" Margin="0,2">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="#238636"/>
                                                                    <Setter Property="BorderThickness" Value="1"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsExecuted}" Value="True">
                                                                    <DataTrigger.EnterActions>
                                                                        <BeginStoryboard>
                                                                            <Storyboard>
                                                                                <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                                                From="#161B22" To="#1C2128" Duration="0:0:0.3"/>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </DataTrigger.EnterActions>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                                                            <Border Background="#0D419D" CornerRadius="4" Padding="8,4">
                                                                <TextBlock Text="{Binding Order}" FontSize="12" FontWeight="Bold" Foreground="#58A6FF"/>
                                                            </Border>
                                                            <Border Background="#E36209" 
                                                                    CornerRadius="4" Padding="6,2" Margin="6,0,0,0"
                                                                    Visibility="{Binding IsReply, Converter={StaticResource BoolToVisibility}}">
                                                                <TextBlock Text="رد" FontSize="10" Foreground="#F0F6FC"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1" Text="{Binding Command}" FontSize="14" FontWeight="SemiBold" 
                                                                   Foreground="#F0F6FC" FlowDirection="LeftToRight" VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                            <Button Content="▲" 
                                                                    Command="{Binding DataContext.MoveSequentialCommandUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource GhostButton}" Padding="8,4" FontSize="10"/>
                                                            <Button Content="▼" 
                                                                    Command="{Binding DataContext.MoveSequentialCommandDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource GhostButton}" Padding="8,4" FontSize="10"/>
                                                            <Button Content="🗑" 
                                                                    Command="{Binding DataContext.RemoveSequentialCommandCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource RedButton}" Padding="8,4" FontSize="10"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                                <Button Content="▶ تنفيذ الأوامر" 
                                        Command="{Binding ExecuteSequentialCommandsCommand}"
                                        Style="{StaticResource OrangeButton}" Padding="20,12"
                                        IsEnabled="{Binding IsSequentialRunning, Converter={StaticResource InverseBoolConverter}}"
                                        Visibility="{Binding IsSequentialRunning, Converter={StaticResource InverseBoolToVisibility}}"/>
                                <Button Content="⏹ إيقاف" 
                                        Command="{Binding StopSequentialExecutionCommand}"
                                        Style="{StaticResource RedButton}" Padding="20,12"
                                        Visibility="{Binding IsSequentialRunning, Converter={StaticResource BoolToVisibility}}"/>
                                <Button Content="🗑 مسح الكل" 
                                        Command="{Binding ClearSequentialCommandsCommand}"
                                        Style="{StaticResource GhostButton}"
                                        IsEnabled="{Binding IsSequentialRunning, Converter={StaticResource InverseBoolConverter}}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardPanel}" Margin="6,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="📜" FontSize="18" Margin="0,0,8,0"/>
                                <TextBlock Text="سجل التنفيذ" FontSize="16" FontWeight="Bold" Foreground="#F0F6FC"/>
                            </StackPanel>

                            <Border Grid.Row="1" Background="#0D1117" CornerRadius="6" BorderBrush="#30363D" BorderThickness="1" Padding="12">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBlock Text="{Binding SequentialUssdLog}" 
                                               FontFamily="Consolas" FontSize="12" Foreground="#C9D1D9"
                                               TextWrapping="Wrap"/>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="🔐 OTP السحب" Style="{StaticResource TabItemStyle}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardPanel}" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔐" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="توليد OTP للسحب من ATM" FontSize="18" FontWeight="Bold" Foreground="#F0F6FC" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border Background="#238636" CornerRadius="6" Padding="16,8" Margin="8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="💰 إجمالي المسحوب:" Foreground="White" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding TotalWithdrawnAmount, StringFormat='{}{0:N0} ج.م'}" 
                                                   Foreground="White" FontWeight="Bold" FontSize="16"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#0D419D" CornerRadius="6" Padding="12,8" Margin="4,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="✅" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding SuccessfulWithdrawals}" Foreground="#C9D1D9" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#D29922" CornerRadius="6" Padding="12,8" Margin="4,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⏳" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding PendingWithdrawals}" Foreground="White" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <Button Grid.Column="2" Content="🔄 جلسة جديدة" 
                                    Command="{Binding StartNewWithdrawalSessionCommand}"
                                    Style="{StaticResource BlueButton}"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="350"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,10,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock Text="⚙" FontSize="18" Margin="0,0,8,0"/>
                                    <TextBlock Text="إعدادات OTP" FontSize="16" FontWeight="Bold" Foreground="#F0F6FC"/>
                                </StackPanel>

                                <TextBlock Text="المبلغ:" Foreground="#8B949E" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding OtpAmount, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>

                                <TextBlock Text="الرقم السري (PIN):" Foreground="#8B949E" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding OtpPin, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>

                                <Border Background="#21262D" CornerRadius="6" Padding="12" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="📋 ملاحظات:" Foreground="#F0F6FC" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <TextBlock Text="• Vodafone: صلاحية 15 دقيقة" Foreground="#E60000" FontSize="12"/>
                                        <TextBlock Text="• Orange: صلاحية 3 دقائق" Foreground="#FF7900" FontSize="12"/>
                                        <TextBlock Text="• Etisalat: صلاحية 15 دقيقة" Foreground="#80B826" FontSize="12"/>
                                    </StackPanel>
                                </Border>

                                <Button Content="▶ توليد OTP للمحدد" 
                                        Command="{Binding GenerateOtpForAllCommand}"
                                        Style="{StaticResource OrangeButton}" 
                                        FontSize="15" Padding="20,14"
                                        IsEnabled="{Binding IsOtpGenerating, Converter={StaticResource InverseBoolConverter}}"
                                        HorizontalAlignment="Stretch"/>

                                <Button Content="🗑 مسح الكل" 
                                        Command="{Binding ClearAllOtpsCommand}"
                                        Style="{StaticResource GhostButton}" 
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardPanel}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock Text="📱" FontSize="18" Margin="0,0,8,0"/>
                                    <TextBlock Text="نتائج OTP" FontSize="16" FontWeight="Bold" Foreground="#F0F6FC"/>
                                </StackPanel>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding OtpResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,10" CornerRadius="8" Padding="16"
                                                        BorderThickness="2">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#0D1117"/>
                                                            <Setter Property="BorderBrush" Value="#30363D"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsWithdrawn}" Value="True">
                                                                    <Setter Property="Background" Value="#0D2818"/>
                                                                    <Setter Property="BorderBrush" Value="#238636"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsExpired}" Value="True">
                                                                    <Setter Property="Background" Value="#2D1117"/>
                                                                    <Setter Property="BorderBrush" Value="#DA3633"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0">
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                                <TextBlock Text="📞 Phone:" Foreground="#8B949E" Margin="0,0,8,0"/>
                                                                <TextBlock Text="{Binding PhoneNumber}" Foreground="#F0F6FC" 
                                                                           FontWeight="SemiBold" FontSize="15"/>
                                                                <Border Margin="12,0,0,0" CornerRadius="4" Padding="8,2">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding OperatorName}" Value="Vodafone">
                                                                                    <Setter Property="Background" Value="#E60000"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding OperatorName}" Value="Orange">
                                                                                    <Setter Property="Background" Value="#FF7900"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding OperatorName}" Value="Etisalat">
                                                                                    <Setter Property="Background" Value="#80B826"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock Text="{Binding OperatorName}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                                                </Border>
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="🔐 OTP:" Foreground="#8B949E" Margin="0,0,8,0"/>
                                                                <TextBlock Text="{Binding OtpCode}" Foreground="#58A6FF" 
                                                                           FontWeight="Bold" FontSize="22" FontFamily="Consolas"/>
                                                                <TextBlock Text="{Binding Amount, StringFormat=' ({0} ج.م)'}" 
                                                                           Foreground="#8B949E" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <Border Grid.Column="1" CornerRadius="6" Padding="12,8" Margin="10,0"
                                                                VerticalAlignment="Center">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#D29922"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsExpired}" Value="True">
                                                                            <Setter Property="Background" Value="#DA3633"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsWithdrawn}" Value="True">
                                                                            <Setter Property="Background" Value="#238636"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <StackPanel>
                                                                <TextBlock HorizontalAlignment="Center" Foreground="White" FontSize="11">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="⏱ باقي"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsExpired}" Value="True">
                                                                                    <Setter Property="Text" Value="❌ انتهى"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding IsWithdrawn}" Value="True">
                                                                                    <Setter Property="Text" Value="✅ تم"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock Text="{Binding RemainingTimeDisplay}" 
                                                                           Foreground="White" FontWeight="Bold" FontSize="16"
                                                                           HorizontalAlignment="Center"
                                                                           Visibility="{Binding IsWithdrawn, Converter={StaticResource InverseBoolToVisibility}}"/>
                                                            </StackPanel>
                                                        </Border>

                                                        <Button Grid.Column="2" Content="✓" 
                                                                Command="{Binding DataContext.ConfirmWithdrawalCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource ModernButton}" 
                                                                Width="50" Height="50" FontSize="20" Padding="0"
                                                                VerticalAlignment="Center"
                                                                Visibility="{Binding IsWithdrawn, Converter={StaticResource InverseBoolToVisibility}}">
                                                            <Button.IsEnabled>
                                                                <MultiBinding Converter="{StaticResource OtpVisibilityConverter}">
                                                                    <Binding Path="IsWithdrawn"/>
                                                                    <Binding Path="IsExpired"/>
                                                                </MultiBinding>
                                                            </Button.IsEnabled>
                                                        </Button>

                                                        <Button Grid.Column="3" Content="✗" 
                                                                Command="{Binding DataContext.CancelOtpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource RedButton}" 
                                                                Width="50" Height="50" FontSize="20" Padding="0"
                                                                VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

        </TabControl>

        <Border Grid.Row="2" Background="#161B22" BorderBrush="#30363D" BorderThickness="0,1,0,0" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="#3FB950" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#8B949E" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Modem Pool Manager Pro v2.0" Foreground="#484F58" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
